cat > .gitignore <<'EOF'
# dependencies
node_modules/
frontend/node_modules/
.pnp
.pnp.js

# testing
coverage/
frontend/coverage/

# production
build/
frontend/build/

# env
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# misc
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*
EOF